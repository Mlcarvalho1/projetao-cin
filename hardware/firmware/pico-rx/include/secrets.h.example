#pragma once

// Copie este arquivo para `secrets.h` (que está no .gitignore) e preencha.
#include <cstdint>

namespace aquasense::rx::secrets {

// PSK: 32 bytes aleatórios. Unused no MVP (RX lê sensores direto, sem rádio).
// Quando o link LoRa entrar (Etapa 6), TX e RX da mesma fazenda devem
// compartilhar exatamente esta chave pro HMAC do frame.
//   Gerar:  openssl rand -hex 32
constexpr uint8_t PSK[32] = {
    0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,
    0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,
    0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,
    0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,
};

constexpr const char* WIFI_SSID = "your-ssid";
constexpr const char* WIFI_PASS = "your-password";

// Endpoint da API. No MVP usamos http; ao virar produção, troque pra https://
// e mude AQUASENSE_TLS_VERIFY=1 no platformio.ini.
constexpr const char* API_URL    = "http://your-server.example.com/readings";
constexpr const char* API_TOKEN  = "replace-with-bearer-token";

} // namespace aquasense::rx::secrets
