#include <cstdint>

namespace aquasense::tx::secrets {

// PSK: 32 bytes aleatórios. Mesma chave do RX da mesma fazenda.
//   Gerar:  openssl rand -hex 32
constexpr uint8_t PSK[32] = {
    0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,
    0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,
    0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,
    0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,
};

} // namespace aquasense::tx::secrets
